{
  "name": "@ikonbai/kioku-sdk",
  "version": "0.2.0",
  "description": "Official SDK for KIOKU™ Agent Memory, Deliberation, Webhooks & External Agent API by IKONBAI™",
  "keywords": [
    "kioku",
    "ikonbai",
    "ai",
    "agent",
    "memory",
    "deliberation",
    "multi-agent",
    "webhooks",
    "external-agents"
  ],
  "author": "IKONBAI™ <dev@ikonbai.com>",
  "license": "MIT",
  "homepage": "https://usekioku.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ikonai-gif/kioku.git",
    "directory": "packages/sdk"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
