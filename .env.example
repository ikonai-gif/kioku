# --- Google OAuth (Google Drive + Gmail integrations) ----------------------
# Required for Google Drive and Gmail OAuth flows. Create an OAuth 2.0 Client
# ID of type "Web application" in Google Cloud Console → APIs & Services →
# Credentials. Add the redirect URIs below as "Authorized redirect URIs".
#
# GOOGLE_CLIENT_ID=        # OAuth 2.0 Client ID (e.g. 1234567890-abc.apps.googleusercontent.com)
# GOOGLE_CLIENT_SECRET=    # OAuth 2.0 Client Secret
#
# Redirect URIs — must match EXACTLY what is registered in Google Cloud Console.
# GOOGLE_REDIRECT_URI=     # e.g. https://your-app.railway.app/api/integrations/google/callback
# GMAIL_REDIRECT_URI=      # e.g. https://your-app.railway.app/api/integrations/gmail/callback
#
# If GOOGLE_REDIRECT_URI / GMAIL_REDIRECT_URI are omitted, they are derived
# from APP_URL automatically (APP_URL + /api/integrations/google/callback etc.)
#
# Required Google API scopes (enabled in Google Cloud Console → APIs & Services → Library):
#   - Google Drive API  (for Drive integration)
#   - Gmail API         (for Gmail integration)
#   - Google People API or OAuth2 userinfo (for email lookup after auth)
#
# NOTE: If you receive "invalid_grant" errors the refresh token has been revoked.
# You must re-authorize via the OAuth connect flow (see docs/google-oauth-reauth.md).

# --- Dropbox OAuth ---------------------------------------------------------
# Required for Dropbox integration. Create an app at https://www.dropbox.com/developers
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=
# DROPBOX_REDIRECT_URI=    # e.g. https://your-app.railway.app/api/integrations/dropbox/callback

# --- Luca V1a (all default OFF; three-gate flag defense) -------------------
# Master + tools-master + per-tool — ALL three must be true to expose a tool.
# Turn on progressively as individual tool PRs land and you validate in staging.
# LUCA_V1A_ENABLED=false            # master switch for Luca V1a tool surface
# LUCA_TOOLS_ENABLED=false          # tools-master: tool registry
# LUCA_TOOL_RUN_CODE_ENABLED=false  # Day 2 (PR #39)
# LUCA_TOOL_ANALYZE_IMAGE_ENABLED=false  # Day 3
# LUCA_TOOL_SEARCH_ENABLED=false    # Day 4
# LUCA_TOOL_READ_URL_ENABLED=false  # Day 5 — browser (untrusted-by-policy)
# LUCA_TOOL_READ_MEMORY_ENABLED=false
# LUCA_TOOL_WRITE_MEMORY_ENABLED=false
# LUCA_TOOL_READ_FILE_ENABLED=false
# LUCA_TOOL_UPLOAD_FILE_ENABLED=false
# LUCA_S3_BUCKET=                   # Private bucket for plots/caches (Day 1.5)
# LUCA_DRIVE_ROOT_FOLDER=           # drive_save_file sanity fence root
# AWS_REGION=eu-central-1           # SF4 regional S3 whitelist in analyze_image
# BRAVE_SEARCH_API_KEY=             # Day 5 search fallback

# --- Luca Notion (IKON_SYSTEM workspace) -----------------------------------
# Read scope and write scope have separate per-tool flags so reads can ship
# first, then writes after smoke testing. Writes are additionally hard-
# whitelisted to MEETING_ROOM + 07_MEMORY parents inside the handlers.
# LUCA_NOTION_SCOPE_ENABLED=false           # scope-master for all 4 notion_* tools
# LUCA_TOOL_NOTION_READ_ENABLED=false       # luca_notion_search + luca_notion_fetch
# LUCA_TOOL_NOTION_WRITE_ENABLED=false      # luca_notion_append + luca_notion_create
# NOTION_INTEGRATION_TOKEN=secret_xxxxxxxxxxxxxxxxx
# NOTION_WORKSPACE_ID=ikon-system-workspace-id  # informational; not used at runtime today

# --- Legacy Luca flag (default ON; NOT the V1a master) ---------------------
# Guards pre-V1a routes/middleware. Unrelated to LUCA_V1A_ENABLED above.
# LUCA_ENABLED=true
