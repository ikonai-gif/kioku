DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kioku
JWT_SECRET=your-jwt-secret
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
KIOKU_MASTER_KEY=your-master-key
BREVO_API_KEY=xkeysib-...
APP_URL=http://localhost:5000
NODE_ENV=development
PORT=5000
DEFAULT_DELIBERATION_MODEL=gpt-4o
REDIS_URL=redis://localhost:6379

# --- Luca V1a (all default OFF; three-gate flag defense) -------------------
# Master + tools-master + per-tool — ALL three must be true to expose a tool.
# Turn on progressively as individual tool PRs land and you validate in staging.
# LUCA_V1A_ENABLED=false            # master switch for Luca V1a tool surface
# LUCA_TOOLS_ENABLED=false          # tools-master: tool registry
# LUCA_TOOL_RUN_CODE_ENABLED=false  # Day 2 (PR #39)
# LUCA_TOOL_ANALYZE_IMAGE_ENABLED=false  # Day 3
# LUCA_TOOL_SEARCH_ENABLED=false    # Day 4
# LUCA_TOOL_READ_URL_ENABLED=false  # Day 5 — browser (untrusted-by-policy)
# LUCA_TOOL_READ_MEMORY_ENABLED=false
# LUCA_TOOL_WRITE_MEMORY_ENABLED=false
# LUCA_TOOL_READ_FILE_ENABLED=false
# LUCA_TOOL_UPLOAD_FILE_ENABLED=false
# LUCA_S3_BUCKET=                   # Private bucket for plots/caches (Day 1.5)
# LUCA_DRIVE_ROOT_FOLDER=           # drive_save_file sanity fence root
# AWS_REGION=eu-central-1           # SF4 regional S3 whitelist in analyze_image
# BRAVE_SEARCH_API_KEY=             # Day 5 search fallback

# --- Legacy Luca flag (default ON; NOT the V1a master) ---------------------
# Guards pre-V1a routes/middleware. Unrelated to LUCA_V1A_ENABLED above.
# LUCA_ENABLED=true
